{
  "venom_id": "git",
  "package_id": "git",
  "kind": "git",
  "version": "1",
  "release_version": "0.5.2",
  "channel": "stable",
  "digest": "sha256:git-v0.5.2",
  "signature": {
    "scheme": "spider-dev-envelope-v1",
    "key_id": "spider-dev-local",
    "value": "git-v0.5.2"
  },
  "trust": {
    "mode": "signed",
    "publisher": "SpiderVenoms",
    "allow_dev_unsigned": false
  },
  "state": "online",
  "categories": ["developer", "scm"],
  "host_roles": ["node"],
  "binding_scopes": ["workspace"],
  "runtime_kind": "native",
  "requirements": {
    "host_capabilities": ["local_fs_export"]
  },
  "endpoints": ["/nodes/{node_id}/venoms/git"],
  "mounts": [
    {
      "mount_id": "git",
      "mount_path": "/nodes/{node_id}/venoms/git",
      "state": "online"
    }
  ],
  "capabilities": {
    "invoke": true,
    "discoverable": true,
    "operations": ["sync_checkout", "status", "diff_range"]
  },
  "ops": {
    "model": "namespace",
    "invoke": "control/invoke.json",
    "paths": {
      "invoke": "control/invoke.json"
    }
  },
  "runtime": {
    "type": "native_proc",
    "abi": "namespace-driver-v1",
    "executable_path": "__EXECUTABLE_PATH__",
    "args": ["git", "__EXPORT_ROOT__"],
    "timeout_ms": 300000
  },
  "permissions": {
    "default": "allow-by-default",
    "allow_roles": ["admin", "user"],
    "scope": "project"
  },
  "schema": {
    "model": "namespace-mount"
  },
  "invoke_template": {
    "op": "status",
    "arguments": {
      "checkout_path": "/nodes/local/fs"
    }
  },
  "help_md": "Workspace git service published from the SpiderVenoms managed local bundle."
}
